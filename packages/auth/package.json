{
  "name": "@quilla-fe-kit/auth",
  "version": "0.1.0",
  "description": "Auth primitives for FE projects: pluggable TokenStorage interface plus three default adapters — memory (SSR-safe), localStorage (browser), and cookie (Secure / SameSite). Zero runtime dependencies.",
  "license": "MIT",
  "author": "Max Martinez",
  "homepage": "https://github.com/quilla-kit/quilla-fe-kit/tree/main/packages/auth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quilla-kit/quilla-fe-kit.git",
    "directory": "packages/auth"
  },
  "bugs": {
    "url": "https://github.com/quilla-kit/quilla-fe-kit/issues"
  },
  "keywords": [
    "auth",
    "authentication",
    "token-storage",
    "localStorage",
    "cookie",
    "frontend",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  }
}
