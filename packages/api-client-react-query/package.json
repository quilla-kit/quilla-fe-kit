    "directory": "packages/api-client-react-query"
  },
  "bugs": {
    "url": "https://github.com/quilla-kit/quilla-fe-kit/issues"
  },
  "keywords": [
    "react-query",
    "tanstack-query",
    "react",
    "http",
    "client",
    "occ",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "exports": {
    ".": {
