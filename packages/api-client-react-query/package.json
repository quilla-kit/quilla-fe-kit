{
  "name": "@quilla-fe-kit/api-client-react-query",
  "version": "0.0.0",
  "description": "React Query adapter for @quilla-fe-kit/api-client: QueryClient factory, useQueryBase, mutation base hooks, query meta module augmentation, callback-shaped notification hooks.",
  "license": "MIT",
  "author": "Max Martinez",
  "homepage": "https://github.com/quilla-kit/quilla-fe-kit/tree/main/packages/api-client-react-query",
  "repository": {
